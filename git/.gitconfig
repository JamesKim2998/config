[core]
	editor = nvim
	quotepath = off
	excludesfile = ~/.gitignore_global
	autocrlf = input
	pager = delta
	# fsmonitor = true     # background daemon watches filesystem for changes
	fsmonitor = false      # disabled: IPC round-trip (~11ms) per subprocess costs more than
	                       # raw lstat in repos with many submodules (33 × 11ms = 360ms overhead).
	                       # preload-index lstats all files regardless, so fsmonitor saves nothing.
	untrackedCache = true  # cache untracked files to speed up git status

# workflow ops
[fetch]
	prune = true
[pull]
	rebase = false
	ff = true
[push]
  autoSetupRemote = true
	recurseSubmodules = on-demand
[rebase]
	autoStash = true
[merge]
	conflictstyle = zdiff3
	tool = nvimdiff
[mergetool]
	prompt = false

# diff display
[diff]
  algorithm = histogram
	# show full submodule diffs instead of just commit pointer (lazygit ignores this)
	submodule = diff
	tool = nvimdiff
[difftool]
	prompt = false
[delta]
	tabs = 2
	navigate = true
	dark = true
	syntax-theme = kanagawa
[interactive]
	diffFilter = delta --color-only

# storage/transport
[lfs]
	concurrenttransfers = 64
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
[submodule]
	fetchJobs = 64  # parallel submodule fetch/clone/update

# auth
[credential]
	helper = osxkeychain
[credential "https://github.com"]
	helper =  # clear default helper chain
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =  # clear default helper chain
	helper = !/opt/homebrew/bin/gh auth git-credential
[http "https://ad090e.studioboxcat.com/"]
	extraHeader = X-cab73d: b2d1746d9a7383f9

[include]
	path = ~/.gitconfig.local
